        Object oWebGroup1 is a cWebGroup
            Set psCaption to "Decoding"
            Set piColumnCount to 12
            
            Object oWebForm is a cWebForm
                Set piColumnIndex to 0
                Set piColumnSpan to 12
                Set psLabel to 'Json Web Token'
                Set peLabelPosition to lpTop
            End_Object
            
            Object oWebButton is a cWebButton
                Set piColumnIndex to 10
                Set piColumnSpan to 2
                Set psCaption to 'Decode'
    
                Procedure OnClick
                    Forward Send OnClick
                    Integer iReturnValue
                    String sJWT sReturnValue 
                    String sSubject sIssuer
                    String[] saAudience
                    UBigInt ubiIssuedAt ubiExpiration ubiNotBefore
                    
                    WebGet psValue of oWebForm to sJWT
                    //Decoding
                    Get DecodeString of oJWT sJWT to iReturnValue
                    
                    Get Subject of oJWT to sSubject
                    Get Issuer of oJWT to sIssuer
                    Get Audience of oJWT to saAudience
                    Get IssuedAt of oJWT to ubiIssuedAt
                    Get Expiration of oJWT to ubiExpiration
                    Get NotBefore of oJWT to ubiNotBefore
                    
                    WebSet psValue of oWebForm1 to sSubject
                    WebSet psValue of oWebForm2 to sIssuer
                    If (SizeOfArray(saAudience) > 1) ;
                        WebSet psValue of oWebForm3 to (StrJoinFromArray(saAudience, ' '))
                    Else ;
                        WebSet psValue of oWebForm3 to saAudience[0]
                    WebSet psValue of oWebForm4 to ubiIssuedAt
                    WebSet psValue of oWebForm5 to ubiExpiration
                    WebSet psValue of oWebForm6 to ubiNotBefore
                    
                    If (iReturnValue <> C_JWT_VALID) Begin
                        Send ShowInfoBox ('JWT was invalid for the follwing reason: ' + (ErrorCodeToErrorMessage(oJWT, iReturnValue))) 'Return Value Check signature'
                    End
                End_Procedure
            End_Object
        End_Object
        
        Object oWebGroup2 is a cWebGroup
            Set psCaption to "Encoding"
            Set piColumnCount to 12

            Object oWebForm1 is a cWebForm
                Set psLabel to "Subject"
                Set peLabelPosition to lptop
                Set piColumnSpan to 6
            End_Object

            Object oWebForm2 is a cWebForm
                Set piColumnSpan to 6
                Set psLabel to "Issuer"
                Set peLabelPosition to lptop
                Set piColumnIndex to 6
            End_Object

            Object oWebForm3 is a cWebForm
                Set piColumnSpan to 0
                Set piColumnSpan to 6
                Set psLabel to "Audience"
                Set peLabelPosition to lptop
            End_Object

            Object oWebForm4 is a cWebForm
                Set piColumnSpan to 6
                Set psLabel to "Issued At"
                Set peLabelPosition to lptop
                Set piColumnIndex to 6
                
                Procedure OnLoad
                    Forward Send OnLoad
                    UBigInt ubiUnixTime
                    
                    //We need to substract one hour because we need UTC time.
                    Get CurrentUnixTime to ubiUnixTime
                    Set psValue to ubiUnixTime
                End_Procedure
            End_Object

            Object oWebForm5 is a cWebForm
                Set piColumnSpan to 0
                Set piColumnSpan to 6
                Set psLabel to "Expiration"
                Set peLabelPosition to lptop
                
                Procedure OnLoad
                    Forward Send OnLoad
                    UBigInt ubiUnixTime
                    
                    //We need to substract one hour because we need UTC time.
                    Get CurrentUnixTime to ubiUnixTime
                    //We also need to add a specific amount of time to set the expiredate in the future.
                    Move (ubiUnixTime + 3600) to ubiUnixTime
                    Set psValue to ubiUnixTime
                End_Procedure
            End_Object

            Object oWebForm6 is a cWebForm
                Set piColumnSpan to 6
                Set psLabel to "Not Before"
                Set peLabelPosition to lptop
                Set piColumnIndex to 6
                
                Procedure OnLoad
                    Forward Send OnLoad
                    UBigInt ubiUnixTime
                    
                    //We need to substract one hour because we need UTC time.
                    Get CurrentUnixTime to ubiUnixTime
                    //We also need to add a specific amount of time to set the expiredate in the future.
                    Move (ubiUnixTime - 3600) to ubiUnixTime
                    Set psValue to ubiUnixTime
                End_Procedure
            End_Object
            
            Object oWebCombo is a cWebCombo
                Set piColumnIndex to 6
                Set piColumnSpan to 4
                Set psLabel to "KeyID"
                Set piLabelOffset to 60

                Procedure OnFill
                    Forward Send OnFill
                    Integer iCounter
                    stJWTKey[] stPrivateKeys
                    
                    Get pstaJWTPrivateKeys of oJWT to stPrivateKeys
                    
                    For iCounter from 0  to (SizeOfArray(stPrivateKeys) -1)
                        Send AddComboItem stPrivateKeys[iCounter].sKeyIdentifier stPrivateKeys[iCounter].sKeyIdentifier
                    Loop
                End_Procedure   
            End_Object

            Object oWebButton1 is a cWebButton
                Set piColumnSpan to 2
                Set psCaption to "Encode"
                Set piColumnIndex to 10
            
                Procedure OnClick
                    Boolean bOk
                    String sValue sKeyID
                    UBigInt ubiUnixTime
                    
                    WebGet psValue of oWebForm1 to sValue
                    Set Subject of oJWT to sValue
                    WebGet psValue of oWebForm2 to sValue
                    Set Issuer of oJWT to sValue
                    WebGet psValue of oWebForm3 to sValue
                    If (Pos(' ', sValue)) ;
                        Set Audience_Array of oJWT to (StrSplitToArray(sValue, " "))
                    Else ;
                        Set Audience of oJWT to sValue
                    WebGet psValue of oWebForm4 to ubiUnixTime
                    Set IssuedAt of oJWT to ubiUnixTime
                    WebGet psValue of oWebForm5 to ubiUnixTime
                    Set Expiration of oJWT to ubiUnixTime
                    WebGet psValue of oWebForm6 to ubiUnixTime
                    Set NotBefore of oJWT to ubiUnixTime
                    
                    WebGet psValue of oWebCombo to sKeyID
                    //Encoding
                    Get EncodeString of oJWT sKeyID to sValue
                    WebSet psValue of oWebForm to sValue
                End_Procedure
            End_Object
        End_Object
    End_Object
End_Object
